<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>💬 Live Chat</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <div id="chatView" class="glass-card">
        <div class="chat-header">
            <h2><i class="fas fa-comment"></i> Chat</h2>
            <div class="user-badge">
                <span class="pulse-dot"></span>
                <i class="fas fa-user"></i> <strong id="currentUsername"><%= username %></strong>
                <a href="/" id="logoutLink" class="logout-link"><i class="fas fa-sign-out-alt"></i></a>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-bottom: 8px;">
            <div class="user-count">
                <i class="fas fa-users"></i> <span id="userCount">1</span> online
            </div>
        </div>

        <div id="messages">
            <!-- Messages will be rendered here -->
        </div>

        <form id="messageForm" class="chat-form" action="/send" method="POST">
            <input type="hidden" name="username" value="<%= username %>">
            <input type="text" id="messageInput" name="message" placeholder="Type a message..." autocomplete="off" required>
            <button type="submit" aria-label="Send"><i class="fas fa-paper-plane"></i></button>
        </form>
    </div>

    <script>
        // Client-side functionality
        (function() {
            const username = '<%= username %>';
            const messagesDiv = document.getElementById('messages');
            const messageForm = document.getElementById('messageForm');
            const messageInput = document.getElementById('messageInput');
            const userCountSpan = document.getElementById('userCount');
            const logoutLink = document.getElementById('logoutLink');

            // Function to add a message to the UI
            function addMessageToUI(message) {
                const div = document.createElement('div');
                div.className = 'msg';
                
                if (message.system) {
                    div.classList.add('system');
                    div.innerHTML = `<i class="fas fa-info-circle"></i> ${message.text}`;
                } else {
                    const time = message.timestamp ? new Date(message.timestamp).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) : '';
                    div.innerHTML = `<strong>${escapeHtml(message.username)}</strong> ${escapeHtml(message.text)} <span class="timestamp">${time}</span>`;
                }
                
                messagesDiv.appendChild(div);
                messagesDiv.scrollTop = messagesDiv.scrollHeight;
            }

            function escapeHtml(text) {
                if (!text) return '';
                const map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return String(text).replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            // Handle form submission
            messageForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const text = messageInput.value.trim();
                if (!text) return;

                // Send message via fetch
                fetch('/send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        username: username,
                        message: text
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        messageInput.value = '';
                        messageInput.focus();
                        // Add message to UI immediately
                        addMessageToUI({
                            username: username,
                            text: text,
                            timestamp: Date.now()
                        });
                    }
                })
                .catch(error => console.error('Error sending message:', error));
            });

            // Handle logout
            logoutLink.addEventListener('click', function(e) {
                e.preventDefault();
                fetch('/logout', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                })
                .then(() => {
                    window.location.href = '/';
                })
                .catch(error => console.error('Error logging out:', error));
            });

            // Poll for new messages
            function pollMessages() {
                fetch('/messages')
                    .then(response => response.json())
                    .then(data => {
                        if (data.messages && data.messages.length > 0) {
                            // Clear existing messages
                            messagesDiv.innerHTML = '';
                            // Add all messages
                            data.messages.forEach(msg => {
                                addMessageToUI(msg);
                            });
                        }
                        if (data.userCount) {
                            userCountSpan.textContent = data.userCount;
                        }
                    })
                    .catch(error => console.error('Error polling messages:', error));
            }

            // Initial load
            pollMessages();
            
            // Poll every 2 seconds
            setInterval(pollMessages, 2000);

            // Focus input on load
            messageInput.focus();
        })();
    </script>
</body>
</html>
