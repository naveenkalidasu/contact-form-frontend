<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>✨ Chat App</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div id="indexView" class="glass-card index-container">
        <h1>
            <i class="fas fa-comment-dots"></i> 
            <span>Chat</span><span style="background: linear-gradient(135deg,#f472b6,#fbbf24); -webkit-background-clip:text; background-clip:text; color:transparent;">•</span>
        </h1>
        <div class="sub-glow">join the conversation · live</div>
        <form id="usernameForm" class="index-form" action="/chat" method="POST">
            <div class="input-group">
                <i class="fas fa-user-astronaut"></i>
                <input type="text" id="usernameInput" name="username" placeholder="Choose your username" required autofocus>
            </div>
            <button type="submit" class="btn-primary">
                <i class="fas fa-arrow-right-to-bracket"></i> Join Chat
            </button>
        </form>
        <div style="margin-top: 18px; color: rgba(255,255,255,0.15); font-size: 0.7rem;">
            <i class="fas fa-shield-alt"></i> 100% anonymous
        </div>
    </div>
</body>
</html>
